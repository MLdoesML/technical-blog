---
import { getCollection } from 'astro:content';
import BaseLayout from '../components/layout/BaseLayout.astro';
import PostCard from '../components/ui/PostCard.astro';
import { DOMAIN_LABELS } from '../lib/tags';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const sorted = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Archive" description="All posts.">
  <div class="page-wrapper">
    <header class="archive-header">
      <h1>Archive</h1>
      <nav class="domain-filter">
        <a href="/archive" class="filter-link active">All</a>
        {Object.entries(DOMAIN_LABELS).map(([slug, label]) => (
          <a href={`/tags/${slug}`} class="filter-link">{label}</a>
        ))}
      </nav>
    </header>

    <div class="posts-list">
      {sorted.map(post => (
        <PostCard
          title={post.data.title}
          subtitle={post.data.subtitle}
          date={post.data.date}
          domain={post.data.domain}
          tags={post.data.tags}
          summary={post.data.summary}
          slug={post.id}
        />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .page-wrapper {
    padding-top: var(--space-16);
    padding-bottom: var(--space-20);
  }

  .archive-header {
    margin-bottom: var(--space-12);
    max-width: var(--prose-width);
  }

  h1 {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 400;
    margin-bottom: var(--space-6);
  }

  .domain-filter {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .filter-link {
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    padding: 3px var(--space-3);
    border-radius: 3px;
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s;
  }

  .filter-link:hover,
  .filter-link.active {
    color: var(--color-accent);
    border-color: var(--color-accent);
    text-decoration: none;
  }

  .posts-list {
    max-width: var(--prose-width);
  }
</style>
