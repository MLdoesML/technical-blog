---
import BaseLayout from '../components/layout/BaseLayout.astro';
import '../styles/prose.css';
---

<BaseLayout title="About" description="About the author.">
  <div class="page-wrapper">
    <article class="prose about-prose">
      <h1>About</h1>

      <p>
        <!-- Replace this section with your bio -->
        I am a researcher and practitioner working at the intersection of machine learning,
        economic theory, and the physical sciences. My work spans theoretical foundations
        and applied problems across domains.
      </p>

      <h2>Research interests</h2>
      <ul>
        <li>Generative modeling and score-based methods</li>
        <li>Market design and mechanism theory</li>
        <li>Statistical physics and its connections to learning</li>
      </ul>

      <h2>Contact</h2>
      <p>
        <a href="mailto:you@example.com">you@example.com</a> ·
        <a href="https://github.com/yourusername" target="_blank" rel="noopener">GitHub</a> ·
        <a href="https://twitter.com/yourusername" target="_blank" rel="noopener">Twitter</a>
      </p>
    </article>
  </div>
</BaseLayout>

<style>
  .page-wrapper {
    padding-top: var(--space-16);
    padding-bottom: var(--space-20);
  }

  .about-prose h1 {
    margin-bottom: var(--space-8);
  }
</style>
