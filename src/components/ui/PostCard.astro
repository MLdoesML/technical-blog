---
import { DOMAIN_LABELS } from '../../lib/tags';

interface Props {
  title: string;
  subtitle?: string;
  date: Date;
  domain: string;
  tags: string[];
  summary: string;
  slug: string;
  featured?: boolean;
}

const { title, subtitle, date, domain, tags, summary, slug, featured = false } = Astro.props;

const domainLabel = DOMAIN_LABELS[domain] ?? domain;
const dateFormatted = date.toLocaleDateString('en-US', {
  year: 'numeric', month: 'short', day: 'numeric',
});
---

<article class:list={['post-card', { featured }]}>
  <div class="card-meta">
    <a href={`/tags/${domain}`} class="domain-tag">{domainLabel}</a>
    <time datetime={date.toISOString()}>{dateFormatted}</time>
  </div>
  <h2 class="card-title">
    <a href={`/posts/${slug}`}>{title}</a>
  </h2>
  {subtitle && <p class="card-subtitle">{subtitle}</p>}
  <p class="card-summary">{summary}</p>
  <div class="card-tags">
    {tags.slice(0, 4).map(tag => (
      <span class="tag-pill">{tag}</span>
    ))}
  </div>
</article>

<style>
  .post-card {
    padding: var(--space-8) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .post-card:last-child {
    border-bottom: none;
  }

  .card-meta {
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .domain-tag {
    font-weight: 500;
    color: var(--color-accent);
    text-transform: uppercase;
    font-size: 10px;
    letter-spacing: 0.07em;
    text-decoration: none;
  }

  .domain-tag:hover {
    text-decoration: underline;
  }

  .card-title {
    font-family: var(--font-serif);
    font-size: 1.45rem;
    font-weight: 400;
    line-height: 1.3;
    margin-bottom: var(--space-2);
  }

  .post-card.featured .card-title {
    font-size: 1.75rem;
  }

  .card-title a {
    color: var(--color-text);
    text-decoration: none;
  }

  .card-title a:hover {
    color: var(--color-accent);
  }

  .card-subtitle {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-3);
    line-height: 1.5;
  }

  .card-summary {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin-bottom: var(--space-3);
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
  }

  .tag-pill {
    font-family: var(--font-sans);
    font-size: 11px;
    color: var(--color-text-muted);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 1px var(--space-2);
    border-radius: 3px;
  }
</style>
