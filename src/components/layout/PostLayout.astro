---
import BaseLayout from './BaseLayout.astro';
import { DOMAIN_LABELS } from '../../lib/tags';
import { getReadingTime } from '../../lib/reading-time';
import '../../styles/prose.css';

interface Props {
  title: string;
  subtitle?: string;
  date: Date;
  updated?: Date;
  domain: string;
  tags: string[];
  summary: string;
  math?: boolean;
  toc?: boolean;
  body: string;
}

const {
  title,
  subtitle,
  date,
  updated,
  domain,
  tags,
  summary,
  math = false,
  toc = true,
  body,
} = Astro.props;

const readTime = getReadingTime(body);
const domainLabel = DOMAIN_LABELS[domain] ?? domain;

const dateFormatted = date.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
const updatedFormatted = updated?.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<BaseLayout title={title} description={summary} math={math}>
  <article class="page-wrapper post-article">
    <!-- Post header -->
    <header class="post-header">
      <div class="post-meta">
        <a href={`/tags/${domain}`} class="domain-tag">{domainLabel}</a>
        <span class="meta-sep">·</span>
        <time datetime={date.toISOString()}>{dateFormatted}</time>
        <span class="meta-sep">·</span>
        <span>{readTime}</span>
        {updated && (
          <span class="updated-note">Updated {updatedFormatted}</span>
        )}
      </div>

      <h1 class="post-title">{title}</h1>
      {subtitle && <p class="post-subtitle">{subtitle}</p>}

      <div class="post-tags">
        {tags.map(tag => (
          <a href={`/tags/${tag.toLowerCase().replace(/\s+/g, '-')}`} class="tag-pill">{tag}</a>
        ))}
      </div>
    </header>

    <!-- Post body -->
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .post-article {
    padding-top: var(--space-16);
    padding-bottom: var(--space-20);
  }

  .post-header {
    margin-bottom: var(--space-12);
    max-width: var(--prose-width);
  }

  .post-meta {
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .domain-tag {
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    text-transform: uppercase;
    font-size: 11px;
    letter-spacing: 0.06em;
  }

  .domain-tag:hover {
    text-decoration: underline;
  }

  .meta-sep {
    color: var(--color-border);
  }

  .updated-note {
    margin-left: var(--space-2);
    font-style: italic;
  }

  .post-title {
    font-family: var(--font-serif);
    font-size: 2.4rem;
    font-weight: 400;
    line-height: 1.2;
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  @media (max-width: 640px) {
    .post-title {
      font-size: 1.8rem;
    }
  }

  .post-subtitle {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-style: italic;
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
    line-height: 1.5;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  .tag-pill {
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--color-accent);
    background: var(--color-accent-soft);
    padding: 2px var(--space-3);
    border-radius: 3px;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .tag-pill:hover {
    opacity: 0.75;
    text-decoration: none;
  }
</style>
